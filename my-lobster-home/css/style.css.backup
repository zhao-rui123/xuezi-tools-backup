/** 雪子助手的温馨小家 - 8-bit像素风版 **/

/* ===== 基础设置 - 强像素风 ===== */
:root {
    --lobster-red: #E74C3C;
    --lobster-dark: #C0392B;
    --pixel-bg: #1a1a2e;
    --panel-bg: #2d2d44;
    --text-color: #ECF0F1;
    --accent-color: #F39C12;
    
    /* 8-bit风格房间色 */
    --tea-color: #8B4513;
    --kitchen-color: #FF6B35;
    --game-color: #9C27B0;
    --bath-color: #607D8B;
    --living-color: #2196F3;
    --work-color: #009688;
    --dining-color: #FF9800;
    --bed-color: #673AB7;
    --balcony-color: #4CAF50;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
}

body {
    font-family: 'VT323', monospace;
    background: 
        linear-gradient(180deg, #0f0f23 0%, #1a1a3e 50%, #16213e 100%);
    color: var(--text-color);
    min-height: 100vh;
    padding: 20px;
    overflow-x: hidden;
}

/* 像素点背景 */
body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: 
        radial-gradient(circle, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 20px 20px;
    pointer-events: none;
    z-index: -1;
}

/* ===== 统计面板 - 像素边框 ===== */
.stats-panel {
    position: fixed;
    top: 20px;
    left: 20px;
    background: var(--panel-bg);
    border: 4px solid var(--lobster-red);
    border-radius: 0;
    padding: 16px;
    min-width: 220px;
    box-shadow: 
        4px 4px 0 #000,
        8px 8px 0 rgba(0,0,0,0.3);
    z-index: 1000;
}

.stats-panel::before {
    content: '';
    position: absolute;
    top: -4px;
    left: -4px;
    right: -4px;
    bottom: -4px;
    border: 2px dashed var(--accent-color);
    pointer-events: none;
}

.stats-header {
    font-size: 24px;
    color: var(--accent-color);
    text-align: center;
    margin-bottom: 12px;
    text-shadow: 3px 3px 0 #000;
    border-bottom: 4px solid var(--lobster-red);
    padding-bottom: 8px;
    letter-spacing: 2px;
}

.stat-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 0;
    border-bottom: 2px dashed rgba(255,255,255,0.2);
}

.stat-item:last-child {
    border-bottom: none;
}

.stat-label {
    font-size: 18px;
    color: #BDC3C7;
}

.stat-value {
    font-size: 20px;
    color: var(--accent-color);
    font-weight: bold;
    text-shadow: 2px 2px 0 #000;
}

.location-badge {
    padding: 4px 12px;
    border-radius: 0;
    font-size: 16px;
    background: var(--living-color);
    border: 2px solid #fff;
    box-shadow: 2px 2px 0 #000;
}

/* ===== 游戏容器 ===== */
.game-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 10px;
    padding-left: 260px;
    padding-bottom: 100px;
}

/* ===== 房子标题 - 像素风 ===== */
.house-title {
    text-align: center;
    font-size: 32px;
    color: var(--accent-color);
    margin-bottom: 20px;
    text-shadow: 
        4px 4px 0 #000,
        0 0 20px rgba(243, 156, 18, 0.5);
    letter-spacing: 4px;
    animation: title-blink 2s infinite;
}

@keyframes title-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.9; }
}

/* ===== 房子主体 - 像素方块 ===== */
.house {
    background: #2d2d44;
    border: 6px solid #1a1a2e;
    border-radius: 0;
    padding: 20px;
    box-shadow: 
        0 0 0 4px #000,
        8px 8px 0 rgba(0,0,0,0.5);
    max-width: 700px;
    width: 100%;
    position: relative;
}

.house::after {
    content: '';
    position: absolute;
    top: 10px;
    left: 10px;
    right: 10px;
    bottom: 10px;
    border: 2px dashed rgba(255,255,255,0.1);
    pointer-events: none;
}

/* ===== 房间行布局 ===== */
.room-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin-bottom: 12px;
}

.room-row.center-row {
    grid-template-columns: 1fr 1.8fr 1fr;
}

/* ===== 房间基础样式 - 像素风 ===== */
.room {
    position: relative;
    border-radius: 0;
    overflow: hidden;
    min-height: 110px;
    transition: all 0.2s;
    border: 4px solid #000;
    box-shadow: 4px 4px 0 rgba(0,0,0,0.3);
}

.room:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 rgba(0,0,0,0.3);
}

.room.active {
    border-color: #FFD700;
    box-shadow: 
        0 0 0 4px #FFD700,
        4px 4px 0 rgba(0,0,0,0.3);
    animation: pixel-glow 1s steps(2) infinite;
    z-index: 10;
}

@keyframes pixel-glow {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.2); }
}

/* 房间头部 */
.room-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background: rgba(0,0,0,0.5);
    border-bottom: 2px solid #000;
}

.room-icon {
    font-size: 20px;
}

.room-name {
    font-size: 15px;
    font-weight: bold;
    text-shadow: 2px 2px 0 #000;
}

/* 房间内容 */
.room-content {
    position: relative;
    height: 85px;
    padding: 6px;
}

/* ===== 侧边房间 ===== */
.side-room {
    min-height: 100px;
}

/* ===== 中心客厅 - C位像素版 ===== */
.center-room {
    min-height: 120px;
    background: var(--living-color);
    border: 4px solid #FFD700;
    box-shadow: 
        0 0 0 4px #000,
        6px 6px 0 rgba(0,0,0,0.3),
        inset 0 0 20px rgba(255,255,255,0.1);
}

.center-room .room-header {
    background: #1565C0;
    color: #fff;
}

.center-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: #FFD700;
    color: #000;
    padding: 4px 10px;
    border-radius: 0;
    font-size: 12px;
    font-weight: bold;
    border: 2px solid #000;
    box-shadow: 2px 2px 0 #000;
    animation: pixel-blink 1s steps(1) infinite;
}

@keyframes pixel-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
}

/* ===== 各房间像素风格 ===== */

/* 🍵 茶水室 */
.tea-room {
    background: #D2691E;
}

.tea-room .room-header {
    background: #8B4513;
}

.tea-set {
    position: absolute;
    font-size: 28px;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
}

.zen-plant {
    position: absolute;
    font-size: 22px;
    top: 5px;
    right: 8px;
}

/* 🍳 厨房 */
.kitchen {
    background: #FF6B35;
}

.kitchen .room-header {
    background: #D84315;
}

.cooking {
    position: absolute;
    font-size: 24px;
    bottom: 8px;
    left: 10px;
    animation: flame 0.5s infinite;
}

@keyframes flame {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

.fridge {
    position: absolute;
    font-size: 28px;
    bottom: 8px;
    right: 10px;
}

/* 🎮 游戏室 */
.gameroom {
    background: #9C27B0;
}

.gameroom .room-header {
    background: #6A1B9A;
}

.rgb-setup {
    position: absolute;
    font-size: 30px;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    animation: rgb-shift 2s infinite;
}

@keyframes rgb-shift {
    0% { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
}

.gaming-chair {
    position: absolute;
    font-size: 24px;
    top: 5px;
    right: 8px;
}

/* 🚽 卫生间 */
.bathroom {
    background: #78909B;
}

.bathroom .room-header {
    background: #546E7A;
}

.toilet {
    position: absolute;
    font-size: 26px;
    bottom: 8px;
    left: 10px;
}

.phone {
    position: absolute;
    font-size: 18px;
    bottom: 15px;
    left: 20px;
    animation: vibrate 0.3s infinite;
}

@keyframes vibrate {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-1px); }
    75% { transform: translateX(1px); }
}

/* 📺 客厅 */
.livingroom {
    background: #2196F3;
}

.big-sofa {
    position: absolute;
    font-size: 40px;
    bottom: 5px;
    left: 10px;
}

.tv-center {
    position: absolute;
    font-size: 32px;
    top: 5px;
    right: 10px;
}

.coffee-table {
    position: absolute;
    font-size: 20px;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
}

/* 💻 工作室 */
.workspace {
    background: #009688;
}

.workspace .room-header {
    background: #00796B;
}

.computer {
    position: absolute;
    font-size: 32px;
    bottom: 8px;
    right: 10px;
}

.books {
    position: absolute;
    font-size: 24px;
    top: 5px;
    left: 10px;
}

/* 🍽️ 餐厅 */
.dining {
    background: #FF9800;
}

.dining .room-header {
    background: #F57C00;
}

.dining-table {
    position: absolute;
    font-size: 32px;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
}

.chandelier {
    position: absolute;
    font-size: 24px;
    top: 5px;
    left: 50%;
    transform: translateX(-50%);
    animation: light-blink 2s infinite;
}

@keyframes light-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
}

/* 🛏️ 主卧 */
.bedroom {
    background: #673AB7;
}

.bedroom .room-header {
    background: #512DA8;
}

.bed {
    position: absolute;
    font-size: 36px;
    bottom: 5px;
    left: 50%;
    transform: translateX(-50%);
}

.moon {
    position: absolute;
    font-size: 22px;
    top: 5px;
    right: 8px;
}

/* ===== 通往阳台 ===== */
.balcony-door {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 16px;
    padding: 10px;
    background: rgba(0,0,0,0.3);
    border: 2px dashed rgba(255,255,255,0.3);
}

.arrow-down {
    font-size: 24px;
    color: var(--accent-color);
    animation: bounce-pixel 0.5s steps(2) infinite;
}

@keyframes bounce-pixel {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(4px); }
}

/* ===== 阳台运动场 - 像素风 ===== */
.balcony-playground {
    margin-top: 20px;
    background: #4CAF50;
    border: 6px solid #2E7D32;
    border-radius: 0;
    padding: 16px;
    max-width: 700px;
    width: 100%;
    box-shadow: 8px 8px 0 rgba(0,0,0,0.3);
}

.balcony-header {
    text-align: center;
    font-size: 24px;
    color: #fff;
    text-shadow: 3px 3px 0 #000;
    margin-bottom: 12px;
    border-bottom: 4px solid #2E7D32;
    padding-bottom: 8px;
}

.balcony-content {
    position: relative;
    height: 100px;
    background: 
        linear-gradient(180deg, #87CEEB 0%, #87CEEB 50%, #66BB6A 50%);
    border: 4px solid #000;
}

.sky {
    position: absolute;
    width: 100%;
    height: 50%;
}

.sun {
    position: absolute;
    font-size: 28px;
    top: 8px;
    right: 15px;
    animation: sun-spin 4s linear infinite;
}

@keyframes sun-spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

.cloud {
    position: absolute;
    font-size: 20px;
    top: 10px;
    left: 15px;
    animation: cloud-move 6s linear infinite;
}

@keyframes cloud-move {
    0% { transform: translateX(0); }
    50% { transform: translateX(20px); }
    100% { transform: translateX(0); }
}

.ground {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 50%;
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 0 20px;
}

.equipment {
    font-size: 28px;
}

/* ===== 小龙虾 - 8-bit像素版 ===== */
.lobster {
    position: absolute;
    width: 40px;
    height: 40px;
    z-index: 100;
    transition: all 1.5s steps(8);
}

.lobster-body {
    position: relative;
    width: 100%;
    height: 100%;
}

.body-main {
    position: absolute;
    width: 24px;
    height: 26px;
    background: var(--lobster-red);
    border: 3px solid #000;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
}

.head {
    position: absolute;
    width: 20px;
    height: 16px;
    background: var(--lobster-red);
    border: 3px solid #000;
    top: 2px;
    left: 50%;
    transform: translateX(-50%);
}

.eye {
    position: absolute;
    width: 6px;
    height: 6px;
    background: #fff;
    border: 2px solid #000;
    top: 3px;
}

.eye.left { left: 2px; }
.eye.right { right: 2px; }

.eye::after {
    content: '';
    position: absolute;
    width: 2px;
    height: 2px;
    background: #000;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
}

.antenna {
    position: absolute;
    width: 2px;
    height: 8px;
    background: var(--lobster-red);
    border: 1px solid #000;
    top: -4px;
}

.antenna.left { left: 4px; transform: rotate(-20deg); }
.antenna.right { right: 4px; transform: rotate(20deg); }

.claw {
    position: absolute;
    top: 12px;
}

.claw.left { left: 0; }
.claw.right { right: 0; }

.claw-arm {
    width: 6px;
    height: 10px;
    background: var(--lobster-red);
    border: 2px solid #000;
}

.claw.left .claw-arm { transform: rotate(-30deg); }
.claw.right .claw-arm { transform: rotate(30deg); }

.claw-hand {
    position: absolute;
    top: -4px;
    width: 8px;
    height: 8px;
    background: var(--lobster-red);
    border: 2px solid #000;
}

.claw.left .claw-hand { left: -2px; }
.claw.right .claw-hand { right: -2px; }

.tail {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
}

.tail-seg {
    width: 12px;
    height: 5px;
    background: var(--lobster-dark);
    border: 1px solid #000;
    margin-top: -1px;
}

.tail-fin {
    width: 6px;
    height: 5px;
    background: #922B21;
    margin: -1px auto 0;
}

.shadow {
    position: absolute;
    width: 20px;
    height: 5px;
    background: rgba(0,0,0,0.3);
    bottom: -2px;
    left: 50%;
    transform: translateX(-50%);
}

.emotion-bubble {
    position: absolute;
    top: -15px;
    right: -8px;
    font-size: 16px;
    background: #fff;
    border: 2px solid #000;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 2px 2px 0 #000;
    animation: emotion-bounce 0.5s steps(2) infinite;
}

@keyframes emotion-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-2px); }
}

/* ===== 对话气泡 - 像素风 ===== */
.speech-bubble {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%);
    background: #fff;
    color: #000;
    padding: 12px 24px;
    border: 4px solid #000;
    font-size: 20px;
    box-shadow: 6px 6px 0 rgba(0,0,0,0.3);
    z-index: 1001;
    max-width: 400px;
    text-align: center;
}

.speech-bubble::after {
    content: '';
    position: absolute;
    bottom: -12px;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 0;
    border-left: 12px solid transparent;
    border-right: 12px solid transparent;
    border-top: 12px solid #000;
}

/* ===== 底部状态栏 - 像素风 ===== */
.status-bar {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--panel-bg);
    border: 4px solid var(--lobster-red);
    border-radius: 0;
    padding: 12px 24px;
    display: flex;
    gap: 30px;
    box-shadow: 6px 6px 0 rgba(0,0,0,0.3);
    z-index: 1000;
}

.status-item {
    display: flex;
    align-items: center;
    gap: 8px;
}

.status-item .label {
    color: #BDC3C7;
    font-size: 16px;
}

.status-item span:last-child {
    color: var(--accent-color);
    font-size: 18px;
    font-weight: bold;
    text-shadow: 2px 2px 0 #000;
}

/* ===== 响应式 ===== */
@media (max-width: 900px) {
    .stats-panel {
        position: relative;
        top: 0;
        left: 0;
        margin-bottom: 20px;
        width: 100%;
    }
    
    .game-container {
        padding-left: 20px;
    }
    
    .room-row {
        grid-template-columns: 1fr;
    }
    
    .room-row.center-row {
        grid-template-columns: 1fr;
    }
    
    .room {
        min-height: 90px;
    }
    
    .center-room {
        min-height: 100px;
    }
    
    .status-bar {
        flex-direction: column;
        gap: 8px;
        padding: 12px;
        max-width: 90%;
    }
    
    .house-title {
        font-size: 24px;
    }
}

/* ===== 历史趋势图表面板（近7天总计） ===== */
.charts-panel {
    position: fixed;
    top: 280px;
    left: 20px;
    background: var(--panel-bg);
    border: 4px solid var(--accent-color);
    border-radius: 0;
    padding: 12px;
    width: 220px;
    box-shadow: 
        4px 4px 0 #000,
        8px 8px 0 rgba(0,0,0,0.3);
    z-index: 999;
}

.charts-header {
    font-size: 16px;
    color: var(--accent-color);
    text-align: center;
    margin-bottom: 10px;
    text-shadow: 2px 2px 0 #000;
    border-bottom: 2px dashed var(--accent-color);
    padding-bottom: 6px;
}

.charts-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.total-item {
    display: flex;
    align-items: center;
    gap: 8px;
}

.total-label {
    font-size: 14px;
    color: #BDC3C7;
    width: 45px;
    text-align: right;
}

.total-bar-track {
    flex: 1;
    height: 20px;
    background: rgba(0,0,0,0.3);
    border: 2px solid #000;
    position: relative;
    overflow: hidden;
}

.total-bar-fill {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    transition: width 0.5s ease;
}

.total-bar-fill.tasks { background: #F39C12; }
.total-bar-fill.tokens { background: #E74C3C; }
.total-bar-fill.time { background: #3498DB; }

.total-value {
    position: absolute;
    right: 6px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 11px;
    color: #fff;
    text-shadow: 1px 1px 0 #000;
}

@media (max-width: 900px) {
    .charts-panel {
        position: relative;
        top: 0;
        left: 0;
        width: 100%;
        margin-top: 20px;
    }
}
