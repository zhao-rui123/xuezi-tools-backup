// 省份列表（用于选择器）
export const provinceList = Object.values(electricityPriceData).map(p => ({
  code: p.code,
  name: p.name,
  hasTimeOfUse: p.hasTimeOfUse,
}));

// 获取省份数据（包含时段价格计算）
export function getProvinceData(provinceCode: string, month: number = 1): ProvinceData | null {
  const province = electricityPriceData[provinceCode];
  if (!province) return null;
  
  // 根据省份和月份获取时段配置
  let slots: TimeSlot[] = [];
  
  switch (provinceCode) {
    case 'JS':
      slots = getTimeSlotsForMonth(jsTimeSlots, month);
      break;
    case 'AH':
      slots = month === 1 || month === 7 || month === 8 || month === 9 
        ? ahTimeSlots[1] 
        : ahTimeSlots[2];
      break;
    case 'SD':
      slots = getTimeSlotsForMonth(sdTimeSlots, month);
      break;
    case 'HN':
      slots = getTimeSlotsForMonth(hnTimeSlots, month);
      break;
    case 'GD':
      slots = month >= 7 && month <= 9 ? gdTimeSlots[7] : gdTimeSlots[1];
      break;
    case 'SX':
      slots = getTimeSlotsForMonth(sxTimeSlots, month);
      break;
    case 'BJ':
      slots = getTimeSlotsForMonth(bjTimeSlots, month);
      break;
    case 'HB':
      slots = getTimeSlotsForMonth(hbTimeSlots, month);
      break;
    case 'ZJ':
      slots = getTimeSlotsForMonth(zjTimeSlots, month);
      break;
    case 'SH':
      slots = shTimeSlots[1];
      break;
    case 'SC':
      slots = scTimeSlots[1];
      break;
    case 'YN':
      slots = ynTimeSlots[1];
      break;
    case 'FJ':
      slots = fjTimeSlots[1];
      break;
    case 'HN2':
      slots = hn2TimeSlots[1];
      break;
    case 'HB2':
      slots = hb2TimeSlots[1];
      break;
    case 'TJ':
      slots = tjTimeSlots[1];
      break;
    case 'CQ':
      slots = cqTimeSlots[1];
      break;
    case 'JX':
      slots = jxTimeSlots[1];
      break;
    case 'GZ':
      slots = gzTimeSlots[1];
      break;
    case 'HN3':
      slots = hn3TimeSlots[1];
      break;
    case 'LN':
      slots = lnTimeSlots[1];
      break;
    case 'JL':
      slots = jlTimeSlots[1];
      break;
    case 'HLJ':
      slots = hljTimeSlots[1];
      break;
    case 'SN':
      slots = snTimeSlots[1];
      break;
    case 'GS':
      slots = gsTimeSlots[1];
      break;
    case 'QH':
      slots = qhTimeSlots[1];
      break;
    case 'XJ':
      slots = xjTimeSlots[1];
      break;
    case 'NM':
      slots = nmTimeSlots[1];
      break;
    case 'NMD':
      slots = nmdTimeSlots[1];
      break;
    case 'GX':
      slots = gxTimeSlots[1];
      break;
    case 'NX':
      slots = nxTimeSlots[1];
      break;
    case 'XZ':
      slots = xzTimeSlots[1];
      break;
    default:
      slots = jsTimeSlots[1];
  }
  
  return {
    ...province,
    timeSlots: calculatePrices(slots, provinceCode),
  };
}

// 生成24小时图表数据
export function generate24HourData(provinceCode: string, month: number = 1): ChartDataPoint[] {
  const province = getProvinceData(provinceCode, month);
  if (!province || !province.hasTimeOfUse) return [];
  
  const data: ChartDataPoint[] = [];
  
  for (let hour = 0; hour < 24; hour++) {
    // 找到当前小时对应的时段
    const slot = province.timeSlots.find(s => {
      if (s.end < s.start) { // 跨天的情况
        return hour >= s.start || hour < s.end;
      }
      return hour >= s.start && hour < s.end;
    });
    
    const type = slot?.type || '平段';
    const price = PERIOD_HEIGHTS[type] || 1.0;
    
    data.push({
      time: `${hour.toString().padStart(2, '0')}:00`,
      price,
      type,
      hour,
    });
  }
  
  return data;
}
