// 获取某省份某月的时段配置
function getTimeSlotsForMonth(timeSlots: Record<number, TimeSlot[]>, month: number): TimeSlot[] {
  // 如果该月有特定配置，直接返回
  if (timeSlots[month]) {
    return timeSlots[month];
  }
  
  // 根据月份推断季节配置
  if (timeSlots[1] && timeSlots[7]) {
    // 有冬季和夏季配置
    if (month === 12 || month === 1 || month === 2) {
      return timeSlots[1]; // 冬季
    } else if (month >= 6 && month <= 8) {
      return timeSlots[7]; // 夏季
    } else {
      return timeSlots[3] || timeSlots[2] || timeSlots[1]; // 春秋季或其他
    }
  }
  
  // 返回第一个可用的配置
  return Object.values(timeSlots)[0] || [];
}

// 计算时段价格
function calculatePrices(slots: TimeSlot[], provinceCode: string): TimeSlot[] {
  const multipliers = priceMultipliers[provinceCode] || priceMultipliers['JS'];
  const basePrice = basePrices[provinceCode] || 0.7;
  
  return slots.map(slot => ({
    ...slot,
    price: basePrice * (multipliers[slot.type] || 1.0)
  }));
}

