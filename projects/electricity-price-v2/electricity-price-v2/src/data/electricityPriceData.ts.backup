  '尖峰': 1.5,
  '高峰': 1.3,
  '平段': 1.0,
  '低谷': 0.7,
  '深谷': 0.5,
};

export interface ChartDataPoint {
  time: string;
  price: number;
  type: string;
  hour: number;
}

