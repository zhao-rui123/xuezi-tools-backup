export interface TimeSlot {
  type: '尖峰' | '高峰' | '平段' | '低谷' | '深谷';
  start: number;
  end: number;
  price: number;
}

export interface ProvinceData {
  code: string;
  name: string;
  hasTimeOfUse: boolean;
  note?: string;
  timeSlots: TimeSlot[];
}

