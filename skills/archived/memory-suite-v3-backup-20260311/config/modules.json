{
  "core": {
    "real_time": {
      "enabled": true,
      "priority": 1,
      "description": "实时会话快照保存",
      "parameters": {
        "interval_minutes": 10,
        "max_snapshots": 50,
        "snapshot_file": "current_session.json"
      }
    },
    "archiver": {
      "enabled": true,
      "priority": 2,
      "description": "记忆归档系统",
      "parameters": {
        "archive_days": 7,
        "permanent_days": 30,
        "compress_days": 90,
        "delete_days": 365,
        "compression_format": "zip"
      }
    },
    "indexer": {
      "enabled": true,
      "priority": 3,
      "description": "语义索引引擎",
      "parameters": {
        "interval_hours": 1,
        "index_file": "memory_index.json",
        "max_index_entries": 10000
      }
    },
    "analyzer": {
      "enabled": true,
      "priority": 4,
      "description": "记忆分析引擎",
      "parameters": {
        "daily_report": true,
        "weekly_report": true,
        "monthly_report": true,
        "extract_keywords": true,
        "extract_themes": true
      }
    }
  },
  "apps": {
    "qa": {
      "enabled": true,
      "priority": 5,
      "description": "智能问答系统",
      "parameters": {
        "max_results": 10,
        "min_relevance_score": 0.6,
        "context_window": 5
      }
    },
    "advisor": {
      "enabled": false,
      "priority": 6,
      "description": "决策支持系统",
      "parameters": {
        "confidence_threshold": 0.7
      }
    },
    "recommender": {
      "enabled": false,
      "priority": 7,
      "description": "推荐系统",
      "parameters": {
        "max_recommendations": 5
      }
    },
    "profiler": {
      "enabled": false,
      "priority": 8,
      "description": "用户画像系统",
      "parameters": {
        "update_interval_days": 7
      }
    }
  },
  "integration": {
    "kb_sync": {
      "enabled": true,
      "priority": 9,
      "description": "知识库同步",
      "parameters": {
        "sync_hour": 6,
        "auto_merge": false
      }
    },
    "notifier": {
      "enabled": true,
      "priority": 10,
      "description": "通知系统",
      "parameters": {
        "on_archive": true,
        "on_error": true,
        "on_backup": false,
        "channel": "feishu"
      }
    },
    "backup_helper": {
      "enabled": true,
      "priority": 11,
      "description": "备份协助",
      "parameters": {
        "auto_backup": true,
        "backup_hour": 3
      }
    }
  }
}
