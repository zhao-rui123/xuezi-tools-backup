{
  "name": "memory-processor",
  "version": "1.0.0",
  "description": "记忆智能筛选系统 - 自动分析记忆文件，提取高频关键词和主题，生成永久记忆",
  "author": "雪子助手",
  "tags": ["memory", "analysis", "nlp", "index"],
  "entry": "memory_processor.py",
  "dependencies": [],
  "schedule": {
    "cron": "0 2 1 * *",
    "description": "每月1日凌晨2点自动执行"
  },
  "inputs": {
    "memory_dir": {
      "type": "path",
      "default": "~/.openclaw/workspace/memory",
      "description": "记忆文件目录"
    },
    "output_dir": {
      "type": "path", 
      "default": "~/.openclaw/workspace/memory",
      "description": "输出目录"
    }
  },
  "outputs": {
    "summary": "memory/summary/YYYY-MM-summary.md",
    "keywords_index": "memory/index/keywords.json",
    "themes_index": "memory/index/themes.json",
    "permanent": "memory/permanent/YYYY-MM-permanent.md"
  },
  "commands": {
    "analyze": "python3 memory_processor.py",
    "analyze_specific": "python3 memory_processor.py --month YYYY-MM"
  }
}
