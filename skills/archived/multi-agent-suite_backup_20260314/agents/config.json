{
  "agents": [
    {
      "id": "product",
      "name": "Product",
      "role": "product_manager",
      "description": "产品经理 - 需求分析、PRD编写、优先级排序",
      "capabilities": ["requirements_analysis", "prd_writing", "user_story", "prioritization", "market_research", "ux_design"],
      "prompt_template": "你是Product，产品经理专家。负责需求分析、PRD文档编写、功能优先级排序、用户故事梳理。与用户沟通收集需求，转化为清晰的开发规范。注重用户体验和商业价值。"
    },
    {
      "id": "architect",
      "name": "Architect",
      "role": "system_architect",
      "description": "架构师 - 系统架构设计、技术选型、接口规范",
      "capabilities": ["system_design", "architecture", "er_diagram", "api_design", "tech_stack", "performance", "scalability"],
      "prompt_template": "你是Architect，系统架构师专家。负责系统架构设计、ER图绘制、技术选型、API接口规范制定。设计高性能、可扩展的系统架构，提供完整的技术方案文档。"
    },
    {
      "id": "orchestrator",
      "name": "Orchestrator",
      "role": "project_manager",
      "description": "项目经理 - 任务拆解、进度管理、资源协调",
      "capabilities": ["project_management", "task_decomposition", "resource_allocation", "progress_tracking", "risk_management", "team_coordination"],
      "prompt_template": "你是Orchestrator，项目经理专家。负责任务拆解、进度管理、资源协调、团队协作。制定项目计划，跟踪开发进度，协调各Agent工作，确保项目按时交付。"
    },
    {
      "id": "alpha",
      "name": "Alpha",
      "role": "frontend_engineer",
      "description": "前端工程师 - HTML/CSS/JS界面开发",
      "capabilities": ["html", "css", "javascript", "ui", "responsive", "react", "vue", "frontend"],
      "prompt_template": "你是Alpha，前端UI开发专家。擅长HTML/CSS/JavaScript界面开发，特别是响应式设计和现代前端框架。请使用最佳实践编写清晰、可维护的代码。"
    },
    {
      "id": "bravo",
      "name": "Bravo",
      "role": "backend_engineer",
      "description": "后端工程师 - Python/算法/API开发",
      "capabilities": ["python", "javascript", "algorithm", "backend", "api", "database", "restful", "graphql"],
      "prompt_template": "你是Bravo，后端逻辑开发专家。擅长算法实现、数据处理、API设计、数据库开发。注重代码性能和可扩展性。"
    },
    {
      "id": "charlie",
      "name": "Charlie",
      "role": "feature_engineer",
      "description": "功能工程师 - 功能完善、业务逻辑",
      "capabilities": ["fullstack", "debug", "integration", "refactoring", "business_logic", "feature_development"],
      "prompt_template": "你是Charlie，功能开发专家。擅长功能完善、bug修复、模块整合、业务逻辑实现。注重代码质量和用户体验。"
    },
    {
      "id": "delta",
      "name": "Delta",
      "role": "fix_engineer",
      "description": "修复工程师 - Bug修复、性能优化",
      "capabilities": ["debug", "bug_fix", "performance", "optimization", "troubleshooting", "code_refactoring"],
      "prompt_template": "你是Delta，修复优化专家。负责Bug修复、性能优化、代码重构。快速定位问题，提供高效的解决方案。"
    },
    {
      "id": "echo",
      "name": "Echo",
      "role": "qa_engineer",
      "description": "测试工程师 - 单元测试、集成测试、Code Review",
      "capabilities": ["unit_test", "integration_test", "code_review", "test_automation", "qa", "bug_report"],
      "prompt_template": "你是Echo，测试质量专家。负责单元测试、集成测试、Code Review、缺陷报告。确保代码质量和功能完整性。"
    },
    {
      "id": "kilo",
      "name": "Kilo",
      "role": "devops_engineer",
      "description": "运维工程师 - 部署监控、定时任务、消息通知",
      "capabilities": ["deploy", "monitoring", "ci_cd", "docker", "kubernetes", "notifications", "cron_jobs", "logging"],
      "prompt_template": "你是Kilo，DevOps运维专家。负责部署上线、环境配置、监控告警、定时任务、日志管理。确保系统稳定运行。"
    },
    {
      "id": "foxtrot",
      "name": "Foxtrot",
      "role": "security_expert",
      "description": "安全专家 - 安全审计、漏洞扫描",
      "capabilities": ["security", "audit", "vulnerability_scan", "encryption", "penetration_test", "security_compliance"],
      "prompt_template": "你是Foxtrot，安全审计专家。负责代码安全审查、漏洞扫描、渗透测试、安全合规。确保系统符合安全最佳实践。"
    },
    {
      "id": "golf",
      "name": "Golf",
      "role": "performance_expert",
      "description": "性能专家 - 性能优化、负载测试",
      "capabilities": ["performance", "profiling", "caching", "load_testing", "optimization", "benchmark"],
      "prompt_template": "你是Golf，性能优化专家。负责代码性能分析、系统瓶颈识别、缓存优化、负载测试。确保系统高效运行。"
    },
    {
      "id": "hotel",
      "name": "Hotel",
      "role": "documentation_expert",
      "description": "文档专家 - 技术文档、用户手册",
      "capabilities": ["documentation", "technical_writing", "api_docs", "readme", "tutorials", "user_manual"],
      "prompt_template": "你是Hotel，文档编写专家。负责技术文档、API文档、用户手册、使用教程编写。确保文档清晰易懂。"
    }
  ],
  "waterfall_phases": [
    {
      "phase": "requirement",
      "name": "需求阶段",
      "description": "需求收集、分析、PRD编写",
      "primary_agent": "product",
      "artifacts": ["PRD.md", "功能清单.md", "用户故事.md"],
      "activities": ["需求收集", "需求分析", "PRD编写", "功能清单", "优先级排序", "用户故事"]
    },
    {
      "phase": "design",
      "name": "设计阶段",
      "description": "系统架构设计、数据库设计、接口设计",
      "primary_agent": "architect",
      "artifacts": ["架构设计.md", "ER图.md", "API文档.md", "时序图.md"],
      "activities": ["系统架构设计", "模块划分", "技术选型", "数据库设计", "接口设计", "数据字典"]
    },
    {
      "phase": "development",
      "name": "开发阶段",
      "description": "并行开发、代码规范、Git管理",
      "primary_agent": "orchestrator",
      "artifacts": ["代码包", "Git仓库"],
      "activities": ["任务分配", "并行开发", "代码规范", "Git管理", "代码集成"],
      "participating_agents": ["alpha", "bravo", "charlie", "delta"]
    },
    {
      "phase": "testing",
      "name": "测试阶段",
      "description": "单元测试、集成测试、Code Review",
      "primary_agent": "echo",
      "artifacts": ["测试报告.md", "缺陷报告.md"],
      "activities": ["单元测试", "集成测试", "Code Review", "缺陷报告", "回归测试"],
      "participating_agents": ["echo", "foxtrot", "golf"]
    },
    {
      "phase": "deployment",
      "name": "部署阶段",
      "description": "部署上线、回滚方案、监控告警",
      "primary_agent": "kilo",
      "artifacts": ["部署文档.md", "部署报告.md"],
      "activities": ["环境准备", "部署执行", "健康检查", "回滚方案", "监控配置"],
      "participating_agents": ["kilo", "orchestrator"]
    },
    {
      "phase": "delivery",
      "name": "交付阶段",
      "description": "用户验收、使用文档、培训",
      "primary_agent": "product",
      "artifacts": ["用户手册.md", "运维手册.md", "培训材料.md"],
      "activities": ["用户验收", "使用文档", "培训", "运维手册", "项目总结"]
    }
  ],
  "task_templates": {
    "web_app": {
      "description": "标准Web应用开发",
      "phases": {
        "requirement": {
          "subtasks": [
            {"title": "收集用户需求", "agent": "product", "priority": 1},
            {"title": "编写PRD文档", "agent": "product", "priority": 1},
            {"title": "功能清单梳理", "agent": "product", "priority": 2}
          ]
        },
        "design": {
          "subtasks": [
            {"title": "系统架构设计", "agent": "architect", "priority": 1},
            {"title": "数据库ER图", "agent": "architect", "priority": 1},
            {"title": "API接口设计", "agent": "architect", "priority": 2}
          ]
        },
        "development": {
          "subtasks": [
            {"title": "前端界面开发", "agent": "alpha", "priority": 1},
            {"title": "后端API开发", "agent": "bravo", "priority": 1},
            {"title": "功能整合联调", "agent": "charlie", "priority": 2, "dependencies": ["前端界面开发", "后端API开发"]},
            {"title": "Bug修复优化", "agent": "delta", "priority": 3, "dependencies": ["功能整合联调"]}
          ]
        },
        "testing": {
          "subtasks": [
            {"title": "单元测试编写", "agent": "echo", "priority": 1},
            {"title": "集成测试", "agent": "echo", "priority": 2, "dependencies": ["单元测试编写"]},
            {"title": "Code Review", "agent": "echo", "priority": 2},
            {"title": "安全审计", "agent": "foxtrot", "priority": 3}
          ]
        },
        "deployment": {
          "subtasks": [
            {"title": "环境配置", "agent": "kilo", "priority": 1},
            {"title": "部署执行", "agent": "kilo", "priority": 2},
            {"title": "健康检查", "agent": "kilo", "priority": 3}
          ]
        },
        "delivery": {
          "subtasks": [
            {"title": "用户验收", "agent": "product", "priority": 1},
            {"title": "编写用户手册", "agent": "hotel", "priority": 2}
          ]
        }
      }
    },
    "api_service": {
      "description": "API服务开发",
      "phases": {
        "requirement": {
          "subtasks": [
            {"title": "API需求分析", "agent": "product", "priority": 1},
            {"title": "编写API文档需求", "agent": "product", "priority": 1}
          ]
        },
        "design": {
          "subtasks": [
            {"title": "API架构设计", "agent": "architect", "priority": 1},
            {"title": "数据库设计", "agent": "architect", "priority": 1},
            {"title": "接口文档编写", "agent": "architect", "priority": 2}
          ]
        },
        "development": {
          "subtasks": [
            {"title": "核心API开发", "agent": "bravo", "priority": 1},
            {"title": "业务逻辑开发", "agent": "charlie", "priority": 2},
            {"title": "性能优化", "agent": "delta", "priority": 3}
          ]
        },
        "testing": {
          "subtasks": [
            {"title": "API单元测试", "agent": "echo", "priority": 1},
            {"title": "API集成测试", "agent": "echo", "priority": 2},
            {"title": "性能测试", "agent": "golf", "priority": 3}
          ]
        },
        "deployment": {
          "subtasks": [
            {"title": "Docker镜像构建", "agent": "kilo", "priority": 1},
