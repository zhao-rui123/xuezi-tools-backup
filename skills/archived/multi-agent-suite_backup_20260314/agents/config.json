          ]
        },
        "delivery": {
          "subtasks": [
            {"title": "API文档交付", "agent": "hotel", "priority": 1}
          ]
        }
      }
    },
    "enterprise_project": {
      "description": "企业级大型项目",
      "phases": {
        "requirement": {
          "subtasks": [
            {"title": "业务需求调研", "agent": "product", "priority": 1},
            {"title": "PRD编写", "agent": "product", "priority": 1},
            {"title": "用户体验设计", "agent": "product", "priority": 2},
            {"title": "技术可行性分析", "agent": "architect", "priority": 2}
          ]
        },
        "design": {
          "subtasks": [
            {"title": "系统架构设计", "agent": "architect", "priority": 1},
            {"title": "微服务设计", "agent": "architect", "priority": 1},
            {"title": "数据库设计", "agent": "architect", "priority": 1},
            {"title": "接口规范制定", "agent": "architect", "priority": 2},
            {"title": "技术选型", "agent": "architect", "priority": 2}
          ]
        },
        "development": {
          "subtasks": [
            {"title": "前端开发", "agent": "alpha", "priority": 1},
            {"title": "后端核心开发", "agent": "bravo", "priority": 1},
            {"title": "业务功能开发", "agent": "charlie", "priority": 2},
            {"title": "性能优化", "agent": "delta", "priority": 3}
          ]
        },
        "testing": {
          "subtasks": [
            {"title": "测试计划制定", "agent": "echo", "priority": 1},
            {"title": "单元测试", "agent": "echo", "priority": 1},
            {"title": "集成测试", "agent": "echo", "priority": 2},
            {"title": "安全审计", "agent": "foxtrot", "priority": 2},
            {"title": "性能测试", "agent": "golf", "priority": 3}
          ]
        },
        "deployment": {
          "subtasks": [
            {"title": "CI/CD配置", "agent": "kilo", "priority": 1},
            {"title": "预发布部署", "agent": "kilo", "priority": 2},
            {"title": "生产部署", "agent": "kilo", "priority": 3},
            {"title": "监控配置", "agent": "kilo", "priority": 3}
          ]
        },
        "delivery": {
          "subtasks": [
            {"title": "用户验收测试", "agent": "product", "priority": 1},
            {"title": "培训", "agent": "hotel", "priority": 2},
            {"title": "文档交付", "agent": "hotel", "priority": 2}
          ]
        }
      }
    }
  },
  "quality_standards": {
    "code_style": "PEP 8 + 类型注解",
    "test_coverage": "核心业务 > 80%",
    "code_review": "所有合并必须经过Echo",
    "documentation": "100%完整性",
    "security": "OWASP Top 10检查",
    "performance": "响应时间 < 200ms"
  },
  "deliverables": {
    "requirement": ["PRD.md", "功能清单.md", "用户故事.md", "优先级排序.md"],
    "design": ["系统架构图.png", "ER图.png", "API文档.md", "时序图.png", "数据字典.md"],
    "development": ["源代码", "Git仓库", "README.md"],
    "testing": ["测试报告.md", "缺陷报告.md", "测试用例.xls"],
    "deployment": ["部署文档.md", "部署脚本", "回滚方案.md"],
    "delivery": ["用户手册.md", "运维手册.md", "项目总结.md"]
  }
}
