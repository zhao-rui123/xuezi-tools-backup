{
  "id": "financial_report",
  "name": "财务报表",
  "category": "financial",
  "type": "excel",
  "style": "professional",
  "description": "专业财务报表模板，包含资产负债表、利润表和现金流量表",
  "sheets": [
    {
      "name": "资产负债表",
      "type": "financial",
      "columns": ["项目", "期初余额", "期末余额", "变动额", "变动率"]
    },
    {
      "name": "利润表",
      "type": "financial",
      "columns": ["项目", "本期金额", "上期金额", "同比增减"]
    },
    {
      "name": "现金流量表",
      "type": "financial",
      "columns": ["项目", "本期实际", "上期实际", "差异"]
    }
  ],
  "format": {
    "number_format": "#,##0.00",
    "currency": "¥",
    "percentage": "0.00%"
  }
}
