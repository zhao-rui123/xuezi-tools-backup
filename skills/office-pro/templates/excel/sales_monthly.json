{
  "id": "sales_monthly",
  "name": "月度销售报表",
  "category": "sales",
  "type": "excel",
  "style": "blue",
  "description": "专业的月度销售数据报表模板，包含销售概览、明细数据和统计分析",
  "sheets": [
    {
      "name": "销售概览",
      "type": "summary",
      "charts": ["line", "bar"],
      "kpis": ["总销售额", "总利润", "销售数量"]
    },
    {
      "name": "明细数据",
      "type": "data",
      "columns": ["日期", "产品", "客户", "销售额", "利润", "数量"]
    },
    {
      "name": "统计分析",
      "type": "analysis",
      "metrics": ["平均值", "最大值", "最小值", "增长率"]
    }
  ],
  "format": {
    "date_format": "YYYY-MM-DD",
    "number_format": "#,##0.00",
    "currency": "¥"
  }
}
