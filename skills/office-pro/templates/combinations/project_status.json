{
  "name": "项目进度报告",
  "category": "project",
  "type": "combination",
  "description": "项目管理和进度跟踪报告模板",
  "sections": [
    {
      "type": "header",
      "title": "项目概况",
      "level": 1
    },
    {
      "type": "kpi",
      "metrics": ["完成进度", "剩余时间", "预算使用", "风险数量"]
    },
    {
      "type": "chart",
      "chart_type": "gantt",
      "title": "项目进度时间线",
      "data_source": "task_data"
    },
    {
      "type": "chart",
      "chart_type": "funnel",
      "title": "任务完成漏斗",
      "data_source": "task_funnel"
    },
    {
      "type": "chart",
      "chart_type": "radar",
      "title": "团队绩效",
      "data_source": "performance_data"
    },
    {
      "type": "table",
      "title": "任务清单",
      "data_source": "task_data"
    }
  ],
  "styles": {
    "primary_color": "#3498DB",
    "accent_color": "#F39C12"
  }
}
