#!/bin/bash
# Unified Memory System CLI

PYTHON_PATH="/Users/zhaoruicn/.openclaw/workspace/skills/unified-memory/unified_memory.py"

case "$1" in
    daily)
        python3 "$PYTHON_PATH" daily "${@:2}"
        ;;
    analyze)
        python3 "$PYTHON_PATH" analyze "${@:2}"
        ;;
    recall)
        python3 "$PYTHON_PATH" recall "${@:2}"
        ;;
    session)
        python3 "$PYTHON_PATH" session "${@:2}"
        ;;
    status)
        python3 "$PYTHON_PATH" status
        ;;
    *)
        echo "统一记忆系统 (Unified Memory System)"
        echo ""
        echo "用法: ums <command> [options]"
        echo ""
        echo "命令:"
        echo "  daily           每日记忆管理"
        echo "  analyze         智能分析"
        echo "  recall          增强记忆（重要性分级）"
        echo "  session         会话持久化"
        echo "  status          查看系统状态"
        echo ""
        echo "示例:"
        echo "  ums daily save                    保存每日记忆"
        echo "  ums analyze --month 2026-03       分析指定月份"
        echo "  ums recall store '用户偏好' -i 0.8 存储重要记忆"
        echo "  ums recall search '编程'          搜索记忆"
        echo "  ums session save                  保存会话状态"
        echo "  ums session restore               恢复会话状态"
        ;;
esac
