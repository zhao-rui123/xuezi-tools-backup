#!/usr/bin/env python3
"""
OpenClaw 统一入口脚本
用法: openclaw <command> [options]

Commands:
    review      代码审查
    optimize    代码优化
    fix         自动修复
    security    安全检查
    help        显示帮助

Examples:
    openclaw review myfile.py
    openclaw optimize ./src --apply
    openclaw fix ./src --apply
    openclaw security ./src --format html
"""

import sys
import os
import subprocess
import argparse

# 脚本目录
SCRIPTS_DIR = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'scripts')


def run_review(args):
    """运行代码审查"""
    script = os.path.join(SCRIPTS_DIR, 'code_review.py')
    cmd = [sys.executable, script] + args
    return subprocess.call(cmd)


def run_optimize(args):
    """运行代码优化"""
    script = os.path.join(SCRIPTS_DIR, 'code_optimizer.py')
    cmd = [sys.executable, script] + args
    return subprocess.call(cmd)


def run_fix(args):
    """运行自动修复"""
    script = os.path.join(SCRIPTS_DIR, 'auto_fix.py')
    cmd = [sys.executable, script] + args
    return subprocess.call(cmd)


def run_security(args):
    """运行安全检查"""
    script = os.path.join(SCRIPTS_DIR, 'security_check.py')
    cmd = [sys.executable, script] + args
    return subprocess.call(cmd)


def show_help():
    """显示帮助信息"""
    print(__doc__)
    print("\n详细帮助:")
    print("  openclaw review --help")
    print("  openclaw optimize --help")
    print("  openclaw fix --help")
    print("  openclaw security --help")


def main():
    if len(sys.argv) < 2:
        show_help()
        sys.exit(1)
    
    command = sys.argv[1]
    args = sys.argv[2:]
    
    commands = {
        'review': run_review,
        'optimize': run_optimize,
        'fix': run_fix,
        'security': run_security,
        'help': lambda _: (show_help(), 0)[1],
    }
    
    if command in commands:
        sys.exit(commands[command](args))
    else:
        print(f"未知命令: {command}")
        show_help()
        sys.exit(1)


if __name__ == '__main__':
    main()
